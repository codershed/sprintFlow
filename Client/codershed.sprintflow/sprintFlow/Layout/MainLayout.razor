@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@using System.Security.Claims
@using sprintFlow.Pages.Health
@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject SignOutSessionStateManager SignOutManager
@inject IHttpClientFactory HttpClientFactory
@inject AuthenticationStateProvider authenticationStateProvider

<div class="d-flex flex-column vh-100">
    <!-- TOP NAVBAR -->
    <header class="navbar navbar-dark sticky-top bg-dark flex-md-nowrap p-0 shadow">
        <button class="btn btn-dark d-md-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebarMenu">
            <i class="bi bi-list fs-3"></i>
            <a class="navbar-brand me-0 px-3 fs-6 text-white" href="#">sprint-Flow</a>
        </button>
        <a class="navbar-brand d-none d-md-inline me-0 px-3 fs-6 text-white" href="#">sprint-Flow</a>
        
        <!-- Profile Icon Button (No Image) -->
        
        <AuthorizeView>
            <Authorized>
                <div class="dropdown me-3">
                    <button class="btn btn-dark dropdown-toggle d-flex align-items-center" data-bs-toggle="dropdown" data-bs-auto-close="outside">
                        <i class="bi bi-person-circle fs-5 me-2"></i>
                        <span>@context.User.Identity?.Name</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow">
                        <!-- Submenu Toggle -->
                        <li>
                            <button class="dropdown-item d-flex justify-content-between align-items-center"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#roleSubmenu">
                                <i class="bi bi-chevron-down small"></i>Assigned Roles
                            </button>

                            <!-- The "Submenu" List -->
                            <div class="collapse" id="roleSubmenu" @onclick:stopPropagation="true">
                                <ul class="list-unstyled ps-3 bg-light border-top border-bottom">
                                    @foreach (var role in GetRoles(context))
                                    {
                                        <li><span class='dropdown-item py-1 small text-muted'>@role</span></li>
                                    }
                                </ul>
                            </div>
                        </li>
                        <li>
                            <button class="dropdown-item d-flex justify-content-between align-items-center"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#healthSubmenu">
                                <i class="bi bi-chevron-down small"></i>Health Checks
                            </button>

                            <!-- The "Submenu" List -->
                            <div class="collapse" id="healthSubmenu" @onclick:stopPropagation="true">
                                <ul class="list-unstyled ps-3 bg-light border-top border-bottom">
                                    <li>
                                        <div class="nav-item px-3 mt-3">
                                            <HealthChecks />
                                        </div>
                                    </li>
                                </ul>
                            </div>
                        </li>
                        
                        <li><hr class="dropdown-divider"></li>
                        <li><button class="dropdown-item text-danger" @onclick="BeginSignOut">Log out</button></li>
                    </ul>
                </div>
            </Authorized>
            <NotAuthorized>         
                <p>Unauthorized</p>
            </NotAuthorized>
        </AuthorizeView>
    </header>

    <div class="d-flex flex-grow-1 overflow-hidden">
        <!-- SIDE NAVBAR -->
        <nav class="offcanvas-md offcanvas-start bg-light border-end" tabindex="-1" id="sidebarMenu" style="width: 300px;">
            <div class="offcanvas-header d-md-none border-bottom">
                <h5 class="offcanvas-title">Menu</h5>
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas" data-bs-target="#sidebarMenu"></button>
            </div>

            <div class="offcanvas-body p-3">
                <ul class="nav nav-pills flex-column mb-auto w-100">
                    <li>
                        <NavLink class="nav-link text-dark" href="Projects">
                            <i class="bi bi-kanban me-2"></i> Projects
                        </NavLink>
                    </li>
                    <li>
                        <NavLink class="nav-link text-dark" href="MyTasks">
                            <i class="bi bi-list-task me-2 text-nowrap"></i> My Tasks
                        </NavLink>
                    </li>
                    <li>
                        <NavLink class="nav-link text-dark" href="dashboard">
                            <i class="bi bi-speedometer2 me-2"></i> Dashboard
                        </NavLink>
                    </li>
                    <li>
                        <NavLink class="nav-link text-dark text-nowrap" href="Documents">
                            <i class="bi bi-files me-2"></i> Documents
                        </NavLink>
                    </li>
                    <li>
                        <NavLink class="nav-link text-dark text-nowrap" href="ActivityFeed">
                            <i class="bi bi-activity me-2"></i> Activity Feed
                        </NavLink>
                    </li>
                    <li>
                        <NavLink class="nav-link text-dark" href="Settings">
                            <i class="bi bi-gear me-2"></i> Settings
                        </NavLink>
                    </li>
                </ul>
            </div>
        </nav>

        <!-- DETAILS SECTION (Main Content) -->
        <main class="flex-grow-1 p-4 overflow-auto bg-white">
            <div class="container-fluid">
                @Body
            </div>
        </main>
    </div>


</div>

@code{
   
    private List<string> GetRoles(AuthenticationState context)
    {
        List<string> userRoles = new();
        var claims = context.User.Claims.Select(c => c).ToList();
        
        @foreach (var claim in claims)
        {
            if(claim.Type == ClaimTypes.Role || claim.Type == "roles")
            {
                userRoles.Add(claim.Value);
            }
        }
        return userRoles;
    }  
    
    private async Task BeginSignOut()
    {
        await SignOutManager.SetSignOutState();
        Navigation.NavigateTo("authentication/logout");
    }
}