@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@inject AuthenticationStateProvider AuthStateProvider
@attribute [Authorize(Policy = "CanManageProjects")]

@page "/"
@page "/projects"

<h3>Projects</h3>

<AuthorizeView>
    <Authorized>
        <nav class="navbar bg-body-secondary rounded-2">
            <div class="container-fluid justify-content-end">
                <form class="d-flex ar" role="search">
                    <a href="NewProject" class="btn btn-outline-success">+ New Project</a>
                </form>
            </div>
        </nav>
    </Authorized>
    <NotAuthorized>
        <p>You are not authorized to create projects.</p>
    </NotAuthorized>
</AuthorizeView>


<div class="row mt-3">
    <div class="col-sm-6 mb-3 mb-sm-0">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Project 1</h5>
                <p class="">Owner: Nesia Mienie</p>
                <p class="">Date Crated: 10 February 2026</p>
                <span class="badge rounded-pill bg-body-secondary text-dark">
                    Open
                </span>

                <div class="mt-3">
                    <a href="Project/1" class="btn btn-primary">View Details</a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Project 2</h5>
                <p class="">Owner: Nienke Mienie</p>
                <p class="">Date Crated: 25 February 2026</p>
                <span class="badge rounded-pill bg-body-secondary text-dark">
                    Review
                </span>

                <div class="mt-3">
                    <a href="Project/2" class="btn btn-primary">View Details</a>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="row mt-3">
    <div class="col-sm-6 mb-3 mb-sm-0">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Project 3</h5>
                <p class="">Owner: Francois Mienie</p>
                <p class="">Date Crated: 01 March 2026</p>
                <span class="badge rounded-pill bg-body-secondary text-dark">
                    In Progress
                </span>

                <div class="mt-3">
                    <a href="Project/3" class="btn btn-primary">View Details</a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 mb-3 mb-sm-0">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Project 4</h5>
                <p class="">Owner: Nicoleen Mienie</p>
                <p class="">Date Crated: 20 February 2026</p>
                <span class="badge rounded-pill bg-body-secondary text-dark">
                    Complete
                </span>

                <div class="mt-3">
                    <a href="Project/4" class="btn btn-primary">View Details</a>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        foreach (var claim in user.Claims)
        {
            Console.WriteLine($"Type: {claim.Type}, Value: {claim.Value}");
        }
    }
}